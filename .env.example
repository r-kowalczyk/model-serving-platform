MODEL_SERVING_SERVICE_NAME=model-serving-platform
MODEL_SERVING_SERVICE_ENVIRONMENT=local
MODEL_SERVING_SERVICE_VERSION=0.1.0
MODEL_SERVING_HOST=127.0.0.1
MODEL_SERVING_PORT=8000
MODEL_SERVING_RELOAD=false
MODEL_SERVING_LOG_LEVEL=INFO
MODEL_SERVING_BUNDLE_PATH=./bundles/graphsage
MODEL_SERVING_MAX_TOP_K=25
MODEL_SERVING_DEFAULT_ATTACHMENT_STRATEGY=interaction
MODEL_SERVING_EXTERNAL_API_TIMEOUT_SECONDS=2.0
MODEL_SERVING_EXTERNAL_API_RETRY_COUNT=2
MODEL_SERVING_EXTERNAL_API_RETRY_BACKOFF_SECONDS=0.2
MODEL_SERVING_RESTRICTED_NETWORK_MODE=false
MODEL_SERVING_EXTERNAL_DESCRIPTION_LOOKUP_URL=
MODEL_SERVING_EXTERNAL_INTERACTION_LOOKUP_URL=
MODEL_SERVING_CACHE_BACKEND=file
MODEL_SERVING_CACHE_PATH=./cache
MODEL_SERVING_CACHE_TTL_SECONDS=3600
MODEL_SERVING_METRICS_ENABLED=true
